# =============================================================================
# PRODUCTION / СЕРВЕР (Docker или VPS)
# Скопируйте:  copy .env.prod.example .env
# Запуск:      deploy\up-prod.ps1  или  ./deploy/up-prod.sh
# =============================================================================
# Redis и Celery worker ОБЯЗАТЕЛЬНЫ.
# =============================================================================

DJANGO_SECRET_KEY=change-me-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=erp.example.com,www.erp.example.com,ВАШ_IP_СЕРВЕРА,localhost,127.0.0.1

# После настройки HTTPS (Let's Encrypt / Cloudflare):
# DJANGO_USE_HTTPS=True
# CSRF_TRUSTED_ORIGINS=https://erp.example.com,https://www.erp.example.com

# HTTP-only первый деплой (без TLS) — оставьте DJANGO_USE_HTTPS=False

# PostgreSQL
DB_NAME=chaihana
DB_USER=chaihana
DB_PASSWORD=strong-password-here
DB_HOST=db
DB_PORT=5432

# Redis (кэш, Channels, Celery)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Первый запуск: CREATE_SUPERUSER=1 и задайте пароль ниже, затем верните 0
CREATE_SUPERUSER=0
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=change-me-strong-password

# --- ИИ-ассистент ---
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=https://erp.example.com

GEMINI_API_KEY=

BUSINESS_PHONE=+996700000000
BUSINESS_NAME=Сакура
BUSINESS_ADDRESS=ул. Примерная 1
BUSINESS_HOURS=Ежедневно 10:00–23:00
BUSINESS_PROMOTIONS=
BUSINESS_DELIVERY_INFO=
BUSINESS_BOOKING_INFO=

# Публичный URL сайта (без слэша в конце). HTTPS после сертификата.
ASSISTANT_PUBLIC_URL=https://erp.example.com

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=sakura_secret_2025

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=sakura_verify_2025

META_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=sakura_ig_2025

# Мониторинг (опционально)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
