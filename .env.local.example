# =============================================================================
# ЛОКАЛЬНАЯ РАЗРАБОТКА (Windows / без Docker)
# Скопируйте:  copy .env.local.example .env
# Запуск:      .\run-local.ps1
# =============================================================================
# Redis и Celery worker НЕ НУЖНЫ — задачи выполняются синхронно (dev.py).
# =============================================================================

DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,127.0.0.1:8888

# SQLite используется автоматически (config.settings.dev)
# PostgreSQL и Redis можно не настраивать

# --- ИИ-ассистент (минимум для теста) ---
# Вариант A — Google Gemini напрямую (часто упирается в бесплатный лимит):
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# AI_MODEL=gemini-2.5-flash

# Вариант B — OpenRouter (рекомендуется):
AI_PROVIDER=openai
OPENAI_API_KEY=sk-or-v1-ВАШ_КЛЮЧ
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://127.0.0.1:8888

BUSINESS_PHONE=+996700000000
BUSINESS_NAME=Сакура
BUSINESS_ADDRESS=ул. Примерная 1
BUSINESS_HOURS=Ежедневно 10:00–23:00

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=sakura_secret_2025

# Публичный URL через ngrok (нужен для webhook Telegram):
#   ngrok http 8888
#   ASSISTANT_PUBLIC_URL=https://xxxx.ngrok-free.app
ASSISTANT_PUBLIC_URL=

# WhatsApp / Instagram — только если тестируете на сервере
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=sakura_verify_2025
# META_APP_SECRET=
# INSTAGRAM_VERIFY_TOKEN=sakura_ig_2025
